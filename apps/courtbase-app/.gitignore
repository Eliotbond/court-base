# Vite
*.timestamp-*-*.mjs

# Compiled TS/Vue artefacts under src/ — sources of truth are .ts / .vue,
# the .js are stale outputs that shadow the real source if Vite hits them first.
# Cf. memory `vite_js_shadow_trap`.
src/**/*.vue.js
src/**/*.js
!src/**/vite-env.d.ts

