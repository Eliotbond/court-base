# Env files
.env
.env.local
.env.*.local
apps/web/.env.local

# Node deps
node_modules/

# Vite caches
.vite/
**/node_modules/.vite/

# TS build info
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

# Compiled TS/Vue artefacts under src/ — sources of truth are .ts / .vue,
# the .js are stale outputs from past `tsc --emit` runs and shadow the real
# source if Vite/Node's resolver hits them first.
apps/web/src/**/*.vue.js
apps/web/src/**/*.js

# Web build outputs
apps/web/dist/

# Cloud Functions compiled output
functions/lib/

# Shared-types tarball packed for Firebase deploy (regenerated by scripts)
functions/*.tgz
functions/club-app-shared-types-*.tgz

# Vitest results
**/node_modules/.vite/vitest/results.json

# Claude Code local state (settings, agent worktrees)
.claude/

# OS / editor
.DS_Store
*.log
