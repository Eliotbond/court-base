rules_version = '2';

// =============================================================================
// Firebase Storage Rules — Club Management App
// =============================================================================
// Modèle : un projet Firebase = un club. Pas de filtrage clubId.
// Tous les paths sont gated. Read/write deny par défaut sauf indiqué.
//
// Source de vérité documentée : docs/chantier-registrations.md §4.9 et §5.
//
// CONVENTION DE PATH (à respecter dans le code de l'app register ET de l'app web) :
//   - Uploads registration : `registrations/{uid}/{regId}/{filename}`
//   - Uploads licence      : `licenseRequests/{uid}/{requestId}/{filename}`
// Le segment {uid} est l'UID Firebase Auth de l'uploadeur — il permet la
// validation d'ownership sans cross-document lookup (limitation Storage rules).
// La callable uploadLicenseDocument (Admin SDK) valide que le uid est bien lié
// au memberId de la licenseRequest avant d'accorder ou de signer une URL.
// =============================================================================

service firebase.storage {
  match /b/{bucket}/o {

    // ------------------------------------------------------------------------
    // Helpers
    // ------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isRootAdmin() {
      return isSignedIn() && request.auth.token.rootAdmin == true;
    }
    // Firestore Storage rules ne peuvent pas faire de get() cross-document
    // (limitation Firebase). On scope donc par UID dans le path lui-même.

    // ------------------------------------------------------------------------
    // /registrations/{uid}/{regId}/{file}
    // ------------------------------------------------------------------------
    // Path préfixé par l'UID de l'auteur de la registration. Permet de valider
    // l'ownership uniquement avec request.auth.uid (pas de cross-doc lookup).
    // Côté app register : upload via `registrations/{uid}/{regId}/{filename}`.
    // Côté coach/admin : ils peuvent lire mais pas écrire (l'app web n'upload pas
    // pour le compte du parent ; si besoin, passer par callable).
    match /registrations/{uid}/{registrationId}/{fileName} {
      allow read: if isSignedIn();
      // Auteur uniquement, taille < 10 MB, type image ou PDF.
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
      allow update, delete: if isSignedIn() && request.auth.uid == uid;
    }

    // ------------------------------------------------------------------------
    // /club/logo/{file}
    // ------------------------------------------------------------------------
    // Logo du club affiché dans Settings → Club info + sidebar de l'app.
    // Read : signed-in (logo affiché à tout user authentifié de l'app).
    // Write : signed-in avec contrainte taille + type image. Le seul flow qui
    //   écrit ici est Settings → Club info (admin-only via le routing UI). On
    //   ne peut pas restreindre à `isAdmin()` au niveau Storage (pas de
    //   cross-doc lookup) — la garde réelle est sur Firestore : si un user
    //   non-admin uploade quand même, l'URL n'atterrit jamais dans
    //   `/config/club.logo` (rule write admin-only).
    match /club/logo/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ------------------------------------------------------------------------
    // /licenseRequests/{uid}/{requestId}/{file}
    // ------------------------------------------------------------------------
    // Path préfixé par l'UID de l'uploader. Uploaders possibles, selon la
    // phase du workflow `/licenseRequests` (cf. `LicenseRequestStatus` dans
    // `packages/shared-types/src/license.ts`) :
    //   - Parent (linked member OU guardian) :
    //       * docs initiaux         : `id_front.{ext}`, `id_back.{ext}`,
    //                                 `avs.{ext}`, `transfer_letter_swiss.{ext}`
    //         (uploadés pendant `pending_parent_docs`).
    //       * doc signé re-uploadé  : `signed.pdf`
    //         (uploadé pendant `awaiting_parent_signature`).
    //   - Trésorier (rôle `treasurer` OU claim `rootAdmin`) :
    //       * `signable.pdf`        (uploadé pendant `coach_validated`).
    //       * `payment-proof.{ext}` (uploadé pendant `form_confirmed` ou
    //                                 plus tard, workflow asynchrone).
    //
    // Storage rules ne peuvent pas faire de cross-doc lookup vers Firestore :
    // on ne peut donc PAS gater par "status courant de la /licenseRequests"
    // ni par "le caller est-il bien trésorier" depuis Storage. La garde
    // status + rôle est faite **côté serveur** lorsqu'une callable consomme
    // le fichier (`treasurerUploadSignableDoc`, `treasurerMarkSentAndPaid`,
    // `treasurerConfirmSignedDoc`, `treasurerFinalizeLicense`) — la callable
    // refusera la transition si le caller n'est pas trésorier ou si le
    // status n'est pas le bon.
    //
    // L'enforcement "ce UID est bien lié au memberId du licenseRequest"
    // (côté parent) se fait toujours côté callable. Côté Storage on garde
    // juste : ownership du dossier (`uid` du path == `request.auth.uid`),
    // taille < 10 MB, type image ou PDF.
    match /licenseRequests/{uid}/{requestId}/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
      allow update, delete: if isSignedIn() && request.auth.uid == uid;
    }

    // ------------------------------------------------------------------------
    // /accounting/invoices/{invoiceId}/{file}
    // ------------------------------------------------------------------------
    // Pièces de factures fournisseurs du module Comptabilité (scan / PDF).
    // Read : signed-in (l'enforcement fin treasurer/rootAdmin est sur la
    //   collection Firestore `/invoices` qui porte le `storagePath` — un
    //   non-trésorier ne connaît pas le path car il ne lit pas `/invoices`).
    // Write : signed-in avec contrainte taille < 10 MB + type image ou PDF.
    //   Storage rules ne peuvent pas faire de cross-doc lookup pour vérifier
    //   le rôle ; la garde réelle est sur `/invoices` (write treasurer-only).
    // Cf. docs/compta.md (section Sécurité).
    match /accounting/invoices/{invoiceId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
    }

    // ------------------------------------------------------------------------
    // /members/{memberId}/{file}
    // ------------------------------------------------------------------------
    // Photo licence du membre (format passeport). Réutilisée par le
    // trésorier/admin lors de la création de la licence fédérale.
    // Cf. docs/members/license-photo.md.
    //
    // Read : signed-in (la photo est consommée dans la fiche membre et la vue
    //   review de demande de licence, gated indirectement par les rules
    //   Firestore qui scopent l'accès au doc `/members/{id}`).
    // Write : signed-in + size/MIME contraints. **Pas de cross-doc lookup
    //   vers Firestore** (cohérent avec le pattern de ce fichier — cf.
    //   `/club/logo`, `/accounting/invoices`). La garde réelle "qui peut
    //   uploader" est :
    //     - admin/treasurer : passent par leur UI qui n'écrit que via path
    //       direct (Storage rule + size/MIME suffisent à border l'écrasement).
    //       Le pointeur Firestore `/members/{id}.photoStoragePath` est gated
    //       admin/treasurer côté `firestore.rules` (PR-A.bis) — un
    //       non-autorisé peut techniquement écrire un blob mais le pointeur
    //       Firestore restera vide, donc la photo ne s'affichera jamais dans
    //       l'app.
    //     - coach : passe par une **callable serveur** (`setMemberLicensePhoto`,
    //       à livrer en PR-B/PR-C) qui valide le scope team via l'Admin SDK
    //       (le scope `coach → member` n'est pas exprimable dans une rule
    //       Storage — il faudrait itérer `/teams.playerIds`, ce qui est
    //       impossible dans une rule, et le schéma `/members` ne porte pas
    //       de `teamIds` dénormalisé).
    //   Contraintes : taille ≤ 5 Mo, MIME `image/(jpeg|png|webp)`.
    // Delete : signed-in. Idem write — la garde admin-only effective est
    //   appliquée côté UI + côté Firestore pointer.
    match /members/{memberId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow delete: if isSignedIn();
    }

    // ------------------------------------------------------------------------
    // Catch-all deny
    // ------------------------------------------------------------------------
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
