{
  "name": "@club-app/functions",
  "version": "0.1.0",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bootstrap:root-admin": "tsx scripts/setRootAdmin.ts",
    "backfill:user-member-id": "tsx scripts/backfillUserMemberId.ts",
    "backfill:dues-registered-by-uid": "tsx scripts/backfillDuesRegisteredByUid.ts",
    "backfill:license-request-parent-user-ids": "tsx scripts/backfillLicenseRequestParentUserIds.ts",
    "enable:basketplan": "tsx scripts/enableBasketplan.ts"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.6",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "@club-app/shared-types": "file:club-app-shared-types-0.1.0.tgz",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "~5.6.0",
    "vitest": "^2.1.0"
  }
}
