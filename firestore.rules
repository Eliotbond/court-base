rules_version = '2';

// =============================================================================
// Firestore Security Rules — Club Management App
// =============================================================================
// Source de vérité documentée : docs/firebase.md (section "Security rules").
// Toute modification ici doit être reflétée dans docs/firebase.md.
//
// Modèle : un projet Firebase = un club. Pas de filtrage clubId.
// Rôles : rootAdmin (claim) > admin > coach > official > player (futur).
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helpers --------
    function isSignedIn() {
      return request.auth != null;
    }
    function isRootAdmin() {
      return isSignedIn() && request.auth.token.rootAdmin == true;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasRole(role) {
      return isSignedIn() && (role in userDoc().roles);
    }
    function isAdmin() { return hasRole('admin'); }
    function isCoach() { return hasRole('coach'); }
    // Trésorier — rôle additif portant la responsabilité paiements. Lit toute
    // la collection `/dues` (pas de scope team) et peut marquer un due payé
    // via la callable `markDuePaid`. Pas de droits admin généraux.
    function isTreasurer() { return hasRole('treasurer'); }
    // Secrétaire — rôle additif staff. Peut notamment confirmer une licence
    // via la callable `confirmLicense` (au même titre que treasurer/admin).
    // Pas de droits admin généraux ; jamais suspendu (cf. `callerSuspended`).
    function isSecretary() { return hasRole('secretary'); }
    // Le user est lié à ce member (auto-lecture autorisée).
    function isLinkedMember(memberId) {
      return isSignedIn() && userDoc().memberId == memberId;
    }
    // Le coach est attaché à cette team (via /users/{uid}.teamIds).
    function isCoachOfTeam(teamId) {
      return isCoach() && teamId != null && teamId in userDoc().teamIds;
    }
    // Coach attaché à la team de ce booking parent.
    function isCoachOfBooking(bookingId) {
      return isCoachOfTeam(
        get(/databases/$(database)/documents/bookings/$(bookingId)).data.teamId
      );
    }
    // Le user (typiquement rôle `parent`) est tuteur de ce member
    // (UID listé dans /members/{memberId}.guardianUserIds).
    // Étend la lecture du doc parent + de /private/contact aux tuteurs.
    function isGuardianOf(memberId) {
      // `.data.get('guardianUserIds', [])` plutôt que `.data.guardianUserIds`
      // pour rester safe face aux members legacy qui n'ont jamais eu ce champ
      // posé : un access `.foo` sur un champ absent throw côté Firestore Rules
      // engine, et ce throw refuse la LIST query ENTIÈRE (pas juste le doc
      // évalué). Incident vécu 2026-05-23 sur /dues : un seul member sans
      // `guardianUserIds` rendait `where registeredByUid == uid` impossible
      // pour tous les utilisateurs.
      return isSignedIn() && request.auth.uid in
        get(/databases/$(database)/documents/members/$(memberId)).data.get('guardianUserIds', []);
    }
    // Le membre lié au caller a une licence d'officiel ACTIVE confirmée
    // (`member.officialLicense != null`). Sert à gater l'auto-inscription
    // d'un officiel à un match (cf. `officialAssignments` create self-register).
    //
    // Défense en profondeur : le check SAISON-PRÉCIS (la licence cible-t-elle
    // bien la saison courante ?) N'EST PAS fait ici. Les rules ne peuvent pas
    // connaître à bas coût l'id de la saison active — `/config/club` ne porte
    // pas de pointeur et déterminer la saison `status:'active'` exigerait une
    // query collection (interdite en rules). Le check saison-précis est porté
    // par l'UI et la callable d'assignation ; ici on se contente de
    // `officialLicense != null` comme garde grossière.
    //
    // Accès défensif : `get('officialLicense', null)` tolère un doc membre
    // legacy sans le champ (traité comme « pas de licence »). Suppose un
    // caller non-staff avec `memberId` non-null (les clauses appelantes
    // court-circuitent déjà sur les rôles staff).
    function callerHasOfficialLicense() {
      return isSignedIn()
        && userDoc().memberId != null
        && get(/databases/$(database)/documents/members/$(userDoc().memberId))
             .data.get('officialLicense', null) != null;
    }

    // -------- Membre inactif → accès app club suspendu --------
    // Un membre marqué inactif (`/members/{memberId}.active == false`) est un
    // joueur/officiel ayant quitté le club. Son compte Auth lié perd l'accès
    // aux données de l'app club (mobile / app club — collections `/bookings`,
    // `/matches`, `/venues`, `/notifications`, etc.), MAIS conserve l'accès
    // au portail public `courtbase-register` pour se réinscrire (la callable
    // `confirmRegistration` repose `active:true` sur réutilisation du membre).
    //
    // `callerSuspended()` retourne `true` SSI :
    //  - le caller est signé,
    //  - il n'a AUCUN rôle staff (rootAdmin/admin/coach/treasurer/secretary)
    //    — les comptes staff utilisent le desktop, jamais suspendus,
    //  - son `userDoc().memberId` est non-null,
    //  - le `/members/{memberId}.active` vaut explicitement `false`.
    //
    // Les checks de rôle sont placés AVANT le `get()` sur /members : un compte
    // staff court-circuite et ne paie jamais la lecture supplémentaire.
    // Accès défensif au champ `active` : `.get('active', true)` ⇒ un doc sans
    // le champ est traité comme actif (pas de suspension par omission).
    function callerSuspended() {
      return isSignedIn()
        && !isRootAdmin() && !isAdmin() && !isCoach() && !isTreasurer()
        && !isSecretary()
        && userDoc().memberId != null
        && get(/databases/$(database)/documents/members/$(userDoc().memberId))
             .data.get('active', true) == false;
    }

    // -------- rootAdmin bypass (à placer en premier dans chaque match) --------
    // Approche : check rootAdmin dans chaque règle.

    // ========================================================================
    // /config/club  — singleton config du club
    // ========================================================================
    match /config/club {
      allow read: if isSignedIn();
      allow write: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /users/{uid}
    // ========================================================================
    // Note : `roles` peut contenir `'parent'` (tuteur légal d'un member mineur),
    // en plus de admin/coach/official/player. Les rules n'énumèrent pas les rôles,
    // donc rien à changer ici — la sémantique `parent` est portée par
    // /members/{memberId}.guardianUserIds (cf. helper `isGuardianOf`).
    match /users/{uid} {
      allow read: if isRootAdmin() || isAdmin() || request.auth.uid == uid;
      // Self-create : un user signé peut créer SON propre doc, avec contraintes
      // strictes (roles vides, pas de lien arbitraire à un member, pas de scope
      // coach). Utilisé par l'app register §4.2 — le rôle `parent` est ajouté
      // par la callable submitRegistration côté Admin SDK, jamais par le client.
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.roles.size() == 0
        && request.resource.data.memberId == null
        && request.resource.data.teamIds.size() == 0;
      // Self-update : le user peut éditer son profil (phone, address, displayName,
      // photoURL, profileCompletedAt) mais PAS roles / memberId / teamIds (réservés admin/callable).
      allow update: if isRootAdmin() || isAdmin()
        || (request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['displayName', 'photoURL', 'phone', 'address', 'profileCompletedAt']));
      allow delete: if isRootAdmin() || isAdmin();

      // Tokens de push FCM des appareils du user (app mobile Flutter).
      // L'ID du document EST la chaîne du token (dédup naturelle, multi-device).
      // Self-manage only : un user gère uniquement ses propres tokens. Admin
      // lit pour debug. La Function `fanoutNotification` (Admin SDK) bypasse.
      // Cf. docs/firebase.md (section /users/{uid}/fcmTokens).
      match /fcmTokens/{tokenId} {
        allow read: if isRootAdmin() || isAdmin() || request.auth.uid == uid;
        allow create, update, delete: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // ========================================================================
    // /members, /roles, /invitations
    // ========================================================================
    match /members/{memberId} {
      // Doc parent : pas de contact info. Lisible par tous les rôles club, le
      // membre lui-même, et ses tuteurs (UIDs dans guardianUserIds).
      allow read: if isRootAdmin() || isAdmin() || isCoach() ||
        hasRole('official') || isLinkedMember(memberId) || isGuardianOf(memberId);
      // Write admin-only en v1. `guardianUserIds` et `comms` sont admin-only-write.
      // Les mutations coach (app mobile) passent par des callables Admin SDK qui
      // bypassent cette rule et re-vérifient le scope coach côté serveur :
      //  - `coachCreateMember`     — crée un joueur + l'ajoute à team.playerIds.
      //  - `coachUpdateMember`     — édite firstName/lastName/birthDate/contact +
      //                              `comms.generalRecipients` (le flow anticipé
      //                              ci-dessus pour les mineurs de l'équipe).
      //  - `coachDeactivateMember` — `mode:'bench'` (active=false) ou
      //                              `mode:'archive'` (status='archived', …).
      // Ne PAS ajouter de règle coach-update directe ici (on ouvrirait trop
      // large) — tout passe par les callables.
      //
      // Archive (`status='archived'`, `archivedAt`, `archivedReason`,
      // `archivedByUid`) : posée par callable serveur (`coachDeactivateMember`
      // mode 'archive', ou déclenchée par `refuseRegistration`). PAS d'ouverture
      // client dédiée — la rule admin globale couvre l'Admin SDK.
      allow write: if isRootAdmin() || isAdmin();

      // Contact info isolés ici : email + phone.
      // Lecture : admin, coach, le membre lui-même, et ses tuteurs. PAS les official-only.
      // Écriture : admin et le membre lui-même (les tuteurs ne peuvent PAS écrire en v1).
      match /private/contact {
        allow read: if isRootAdmin() || isAdmin() || isCoach() ||
          isLinkedMember(memberId) || isGuardianOf(memberId);
        allow write: if isRootAdmin() || isAdmin() || isLinkedMember(memberId);
      }
    }
    // Référentiel rôles — résolu par l'app club (web/mobile), PAS par
    // courtbase-register. Lecture coupée pour les membres inactifs.
    //
    // create/update : admin-only. delete : admin-only ET interdit sur les
    // rôles `system` (les 6 rôles canoniques sont non-supprimables — garde
    // serveur, défense en profondeur au-delà du blocage UI).
    match /roles/{roleId} {
      allow read: if isSignedIn() && !callerSuspended();
      allow create, update: if isRootAdmin() || isAdmin();
      allow delete: if (isRootAdmin() || isAdmin())
        && resource.data.type != 'system';
    }
    match /invitations/{inviteId} {
      allow read, write: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /venues + /courts + /timeSlots
    // ========================================================================
    // Données "app club" : non lues par le portail courtbase-register. La
    // lecture est coupée pour les membres inactifs (`!callerSuspended()`).
    match /venues/{venueId} {
      allow read: if isSignedIn() && !callerSuspended();
      allow write: if isRootAdmin() || isAdmin();

      match /courts/{courtId} {
        allow read: if isSignedIn() && !callerSuspended();
        allow write: if isRootAdmin() || isAdmin();

        match /timeSlots/{slotId} {
          allow read: if isSignedIn() && !callerSuspended();
          allow write: if isRootAdmin() || isAdmin();
        }
      }
    }

    // Rule collectionGroup `courts` — indispensable pour `collectionGroup('courts')`
    // utilisé par Venues (load) et Bookings (count par court). Les rules de
    // sous-collection ci-dessus ne s'appliquent PAS aux collectionGroup queries
    // (limitation Firestore : il faut une règle séparée avec wildcard `{path=**}`).
    // Donnée app club → coupée pour les membres inactifs.
    match /{path=**}/courts/{courtId} {
      allow read: if isSignedIn() && !callerSuspended();
    }

    // Rule collectionGroup `refusalLogs` — admin seulement. Permet la vue admin
    // "tous les refus toutes équipes confondues" via collectionGroup('refusalLogs').
    match /{path=**}/refusalLogs/{logId} {
      allow read: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /teams, /categories
    // ========================================================================
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isRootAdmin() || isAdmin();

      // Logs de refus d'inscriptions, écrits uniquement via callable refuseRegistration
      // (Admin SDK). Lecture admin seulement — audit. Cf. docs/chantier-registrations.md §7.2.
      match /refusalLogs/{logId} {
        allow read: if isRootAdmin() || isAdmin();
        allow write: if false;
      }
    }
    // Référentiel catégorie (U14, Seniors, Loisirs…). Read par tout user signé
    // (résolution `team.categoryId` côté client). Write admin only — édité depuis
    // Settings → Catégories.
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isRootAdmin() || isAdmin();
    }
    // Référentiel tag (Élite, Loisir, Compet, U14 A…). Référencé par
    // /teams.tags[].tagId avec un flag display par-équipe. Read signed, write
    // admin only — édité depuis Settings → Tags.
    match /tags/{tagId} {
      allow read: if isSignedIn();
      allow write: if isRootAdmin() || isAdmin();
    }
    // Référentiel cotisations (montant/an/joueur). Référencé par /teams.cotisationId.
    // Read signed, write admin only — édité depuis Settings → Cotisations.
    match /cotisations/{cotisationId} {
      allow read: if isSignedIn();
      allow write: if isRootAdmin() || isAdmin();
    }
    // Référentiel types de licence (rôle × niveau, prix courant). Sera référencé
    // par la future entité /licenses. Write admin only — édité depuis
    // Settings → Licences. Donnée app club — courtbase-register lit
    // `/licenseRequests` mais PAS `/licenseTypes` → lecture coupée pour les
    // membres inactifs.
    match /licenseTypes/{licenseTypeId} {
      allow read: if isSignedIn() && !callerSuspended();
      allow write: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /matchTypes, /seasons, /closurePeriods
    // ========================================================================
    // Données "app club" — pas utilisées par courtbase-register. Lecture
    // coupée pour les membres inactifs (`!callerSuspended()`).
    match /matchTypes/{id} {
      allow read: if isSignedIn() && !callerSuspended();
      allow write: if isRootAdmin() || isAdmin();
    }
    match /seasons/{id} {
      allow read: if isSignedIn() && !callerSuspended();
      allow write: if isRootAdmin() || isAdmin();
    }
    match /closurePeriods/{id} {
      allow read: if isSignedIn() && !callerSuspended();
      allow write: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /bookingSeries — séries de réservations récurrentes (pattern Outlook)
    // ========================================================================
    // Chaque booking instance dans /bookings référence le seriesId. Seuls les
    // admins gèrent les séries (création, édition, suppression) — les coachs
    // ne peuvent pas créer/modifier de série.
    // Donnée app club → lecture coupée pour les membres inactifs.
    match /bookingSeries/{seriesId} {
      allow read: if isSignedIn() && !callerSuspended();
      allow create, update, delete: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /bookings + sub-collections
    // ========================================================================
    // Donnée "app club" — non lue par courtbase-register. Lecture coupée pour
    // les membres inactifs (`!callerSuspended()`). Les clauses write/coach ne
    // sont pas re-gardées : les rôles coach/admin ne déclenchent jamais
    // `callerSuspended` (court-circuit staff).
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && !callerSuspended();
      // Create/delete : admin only (les bookings sont générés par Function ou créés par admin).
      allow create: if isRootAdmin() || isAdmin();
      allow delete: if isRootAdmin() || isAdmin();
      // Update : admin tout, coach uniquement pour sa team + champs limités (cancel + log).
      allow update: if isRootAdmin() || isAdmin() ||
        (isCoachOfTeam(resource.data.teamId) &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'cancelReason', 'actionLog']));

      match /officialAssignments/{assignmentId} {
        allow read: if isSignedIn() && !callerSuspended();
        allow create: if isRootAdmin() || isAdmin() ||
          // Self-register : l'official crée son propre assignment, pour lui-même.
          // Bloqué pour un membre inactif — fonctionnalité app club. Exige en
          // plus une licence d'officiel ACTIVE (`callerHasOfficialLicense()`) :
          // un membre qualifié mais sans licence active ne peut pas s'inscrire.
          // Check saison-précis fait côté UI/callable (cf. helper).
          (isSignedIn() && !callerSuspended() &&
           callerHasOfficialLicense() &&
           request.resource.data.status == 'pending' &&
           request.resource.data.memberId == userDoc().memberId);
        allow update: if isRootAdmin() || isAdmin() ||
          // L'official peut update status + respondedAt sur SA propre assignation
          // (réponse pending → confirmed/declined), et poser/clear
          // `replacementRequestedAt` + `replacementRequestedByUid` pour signaler
          // une demande de remplacement (tab Officiels — métrique tracking).
          // Bloqué pour un membre inactif.
          (!callerSuspended() &&
           resource.data.memberId == userDoc().memberId &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'respondedAt',
                       'replacementRequestedAt', 'replacementRequestedByUid']));
        allow delete: if isRootAdmin() || isAdmin();
      }

      match /attendance/{attendanceId} {
        // Coach restreint à sa team (via teamId du booking parent). Pas de
        // garde inactif nécessaire : seuls admin/coach accèdent (court-circuit staff).
        allow read: if isRootAdmin() || isAdmin() || isCoachOfBooking(bookingId);
        allow write: if isRootAdmin() || isAdmin() || isCoachOfBooking(bookingId);
      }
    }

    // ========================================================================
    // /matches — entité produit match (équipe + type + adversaire + date)
    // ========================================================================
    // Référence bidirectionnelle avec /bookings :
    //  - match HOME : `match.bookingId` ↔ `booking.matchId` (atomicité via
    //    writeBatch côté repo).
    //  - match AWAY : `match.bookingId === null` (pas de booking — date/heure
    //    sont source de vérité sur le match).
    // Cf. docs/firebase.md (section /matches).
    // Donnée "app club" — non lue par courtbase-register. Lecture coupée pour
    // les membres inactifs (`!callerSuspended()`).
    match /matches/{matchId} {
      allow read: if isSignedIn() && !callerSuspended();
      allow create, update, delete: if isRootAdmin() || isAdmin();

      // Assignations d'officiels d'un match À L'EXTÉRIEUR (kind='away') — les
      // matchs away n'ont pas de booking, on porte donc leurs assignations
      // ici. Schéma + permissions identiques à
      // /bookings/{}/officialAssignments (cf. docs/firebase.md).
      match /officialAssignments/{assignmentId} {
        allow read: if isSignedIn() && !callerSuspended();
        allow create: if isRootAdmin() || isAdmin() ||
          // Self-register : l'official crée son propre assignment.
          // Bloqué pour un membre inactif — fonctionnalité app club. Exige en
          // plus une licence d'officiel ACTIVE (`callerHasOfficialLicense()`).
          // Check saison-précis fait côté UI/callable (cf. helper).
          (isSignedIn() && !callerSuspended() &&
           callerHasOfficialLicense() &&
           request.resource.data.status == 'pending' &&
           request.resource.data.memberId == userDoc().memberId);
        allow update: if isRootAdmin() || isAdmin() ||
          // L'official update status + respondedAt sur SA propre assignation,
          // et peut poser/clear `replacementRequestedAt` +
          // `replacementRequestedByUid` (métrique tab Officiels). Bloqué pour
          // un membre inactif.
          (!callerSuspended() &&
           resource.data.memberId == userDoc().memberId &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'respondedAt',
                       'replacementRequestedAt', 'replacementRequestedByUid']));
        allow delete: if isRootAdmin() || isAdmin();
      }
    }

    // ========================================================================
    // /matchRequests
    // ========================================================================
    match /matchRequests/{id} {
      allow read: if isRootAdmin() || isAdmin() || isCoach();
      allow create: if isRootAdmin() || isAdmin() || isCoach();
      allow update, delete: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /notifications
    // ========================================================================
    // Donnée "app club" — non utilisée par courtbase-register. Lecture et
    // marquage `readBy` coupés pour les membres inactifs (`!callerSuspended()`).
    match /notifications/{id} {
      allow read: if isSignedIn() && !callerSuspended();
      allow create: if isRootAdmin() || isAdmin();
      // Tout user peut s'ajouter à readBy[] — uniquement son propre uid, pas de retrait.
      allow update: if isSignedIn() && !callerSuspended() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) &&
        request.resource.data.readBy.toSet()
          .difference(resource.data.readBy.toSet())
          .hasOnly([request.auth.uid]) &&
        resource.data.readBy.toSet()
          .difference(request.resource.data.readBy.toSet())
          .hasOnly([]);
      allow delete: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /dues
    // ========================================================================
    // Coach voit uniquement les dues de ses teams. Pour LIST, le client DOIT
    // filtrer par `teamId` (== ou `in`) pour passer les rules.
    // Treasurer : read all (vue globale paiements). Pas de filtre par team.
    //
    // Lecture parent/membre (app `courtbase-register`) :
    //  - le **membre lié** (`/members/{memberId}.linkedUserId == auth.uid`),
    //  - les **tuteurs** (`/members/{memberId}.guardianUserIds` contient
    //    `auth.uid`),
    //  - le **compte ayant fait l'inscription** (`due.registeredByUid ==
    //    auth.uid`). Ancre directe posée par `initiateDuesOnPlayerActivation`
    //    à la création — couvre le submitter même quand le binding membre
    //    n'a pas pris (ex. `for: 'self'` sur un member déjà lié à un autre
    //    compte). Champ optionnel : `get('registeredByUid', null)` tolère les
    //    lignes legacy. `null` ⇒ aucun compte ne matche via cette clause.
    //
    // Implémentation : `get()` direct sur `/members/{resource.data.memberId}`
    // côté rules — coût = 1 lecture supplémentaire par doc évalué, acceptable
    // car la query côté register filtre `memberId in [...]` (chunk de 30 max)
    // donc au plus quelques docs/évaluation. Cf. notes coût Firestore rules
    // (un get() est facturé en plus de la query elle-même).
    //
    // Sécurité : aucun champ écrit ici par le tuteur ni le membre — la rule
    // `write` reste serrée à admin/rootAdmin. Le canal légitime pour passer
    // `paid` est la callable `markDuePaid` (Admin SDK).
    match /dues/{id} {
      allow read: if isRootAdmin() || isAdmin() || isTreasurer() ||
        (isCoach() && resource.data.teamId in userDoc().teamIds) ||
        // Tuteurs du membre concerné (parent app inscriptions). Réutilise le
        // helper existant `isGuardianOf` qui fait le get() sur /members et
        // vérifie `auth.uid in guardianUserIds`.
        isGuardianOf(resource.data.memberId) ||
        // Membre lié à la cotisation (compte autonome du joueur). Inline
        // plutôt qu'un helper dédié : le check pose un seul get() supplémentaire
        // et reste lisible. NB : différent du helper `isLinkedMember(memberId)`
        // qui s'appuie sur `userDoc().memberId` — ici on doit aller chercher
        // le mapping depuis `/members` car la cotisation ne porte pas
        // directement le linkedUserId.
        (isSignedIn() &&
         get(/databases/$(database)/documents/members/$(resource.data.memberId))
           .data.get('linkedUserId', null) == request.auth.uid) ||
        // Compte ayant soumis l'inscription à l'origine de la cotisation.
        // Check direct sur le doc — aucun get() supplémentaire.
        (isSignedIn() &&
         resource.data.get('registeredByUid', null) == request.auth.uid);
      // Écriture directe : admin/rootAdmin (filets de sécurité). Le passage
      // `paid` standard passe par la callable `markDuePaid` (Admin SDK, scope
      // admin OU treasurer enforcée côté callable). Treasurer n'a PAS de
      // write direct ici — la rule reste serrée pour forcer le canal callable
      // (audit centralisé, snapshot `recordedBy`, etc.).
      allow write: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /paymentExceptionRequests
    // ========================================================================
    match /paymentExceptionRequests/{id} {
      allow read: if isRootAdmin() || isAdmin() ||
        (isCoach() && resource.data.teamId in userDoc().teamIds);
      allow create: if isRootAdmin() || isAdmin() ||
        (isCoach() && request.resource.data.teamId in userDoc().teamIds);
      allow update, delete: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // Module Comptabilité — /accounts, /accountingEntries, /invoices
    // ========================================================================
    // Accès STRICTEMENT réservé au trésorier (`treasurer`) et au `rootAdmin`.
    // L'admin standard est EXCLU de ces collections — la compta est une
    // frontière de sécurité distincte des droits admin généraux. Aucune rule
    // wildcard `/{document=**}` n'ouvre ces paths : l'exclusion admin tient.
    // Cf. docs/compta.md (section Sécurité).
    match /accounts/{id} {
      allow read, write: if isRootAdmin() || isTreasurer();
    }
    // Journal en partie double. Append-only : pas de delete — l'annulation
    // d'une écriture passe par une contre-passation (écriture inverse,
    // `reversed` + `reversalOfEntryId`). Cf. docs/compta.md.
    match /accountingEntries/{id} {
      allow read, create, update: if isRootAdmin() || isTreasurer();
      allow delete: if false;
    }
    // Factures fournisseurs (saisie manuelle en v1, champs OCR réservés).
    match /invoices/{id} {
      allow read, write: if isRootAdmin() || isTreasurer();
    }

    // ========================================================================
    // /licenseRequests
    // ========================================================================
    // Update parent (linked member ou guardian) : autorisé UNIQUEMENT pour
    // compléter le dossier — champs scopés (`uploadedDocs`,
    // `foreignPlayerContext`, `parentSubmittedAvs`, `parentCompletedAt`,
    // `status`) et transition de status verrouillée à
    // `pending_parent_docs → parent_docs_submitted` (ou conservation du status
    // courant pendant le remplissage incrémental). Le re-upload d'un doc
    // (sous-clé `uploadedDocs.<kind>`) entraîne automatiquement le reset des
    // sous-champs `coachReview` / `treasurerReview` à `null` côté client —
    // ces écritures restent couvertes par la whitelist `uploadedDocs`.
    //
    // Le coach review (PR2 : `parent_docs_submitted → coach_validated`) et la
    // décision trésorier (PR3 : `coach_validated → approved|rejected`) passent
    // désormais par 3 callables Admin SDK (livrées 2026-05-24) :
    //   - `coachReviewLicenseDoc({requestId, kind, decision, refusalReason?})`
    //     → coach scope (teamId ∈ user.teamIds) ;
    //   - `treasurerReviewLicenseDoc({requestId, kind, decision, refusalReason?})`
    //     → admin/treasurer/secretary/rootAdmin ;
    //   - `validateLicenseRequest({requestId, decision: 'approve'|'reject', comment?})`
    //     → admin/treasurer/secretary/rootAdmin, crée `/licenses` (pending) sur approve.
    //
    // Ces callables bypassent les rules (Admin SDK) et re-vérifient le scope
    // côté serveur — la rule parent ici ne laisse JAMAIS écrire `approved` /
    // `rejected` / `coach_validated`.
    match /licenseRequests/{id} {
      // Lecture parent (linked member ou guardian) : on s'appuie sur l'ANCRE
      // STATIQUE `parentUserIds` plutôt que sur `isGuardianOf(memberId)` /
      // `isLinkedMember(memberId)`. Raison : `isGuardianOf` fait un `get()`
      // dynamique cross-doc qui peut faire refuser une LIST query côté
      // Firestore (cf. mémoire `firestore-list-query-dynamic-rule` + cas vécu
      // sur `/dues` 2026-05-23). Le coach pose `parentUserIds` à la création
      // (= `member.linkedUserId` ∪ `member.guardianUserIds`).
      //
      // `isLinkedMember(memberId)` est conservé (statique : utilise `userDoc()`
      // qui est un get self) pour rétro-compat sur les docs sans
      // `parentUserIds`, mais le chemin LIST passe désormais par la clause
      // `array-contains` côté query (`where parentUserIds array-contains uid`).
      allow read: if isRootAdmin() || isAdmin()
        || (isCoach() && resource.data.teamId in userDoc().teamIds)
        || (isSignedIn()
            && request.auth.uid in resource.data.get('parentUserIds', []))
        || isLinkedMember(resource.data.memberId)
        || isGuardianOf(resource.data.memberId);
      allow create: if isRootAdmin() || isAdmin() ||
        (isCoach() && request.resource.data.teamId in userDoc().teamIds);
      allow update: if isRootAdmin() || isAdmin()
        // Parent self-update — linked member, guardian, OU UID ancré dans
        // `parentUserIds` (snapshot coach). Champs scopés, status verrouillé
        // sur la transition légitime parent.
        || (
          (
            (isSignedIn()
              && request.auth.uid in resource.data.get('parentUserIds', []))
            || isLinkedMember(resource.data.memberId)
            || isGuardianOf(resource.data.memberId)
          )
          && resource.data.status == 'pending_parent_docs'
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['uploadedDocs', 'foreignPlayerContext',
                         'parentSubmittedAvs', 'parentCompletedAt', 'status'])
          && request.resource.data.status in
               ['pending_parent_docs', 'parent_docs_submitted']
        )
        // ===================================================================
        // Phase trésorier — transitions client-direct
        // ===================================================================
        // Treasurer phase = `rootAdmin` (claim) OU rôle `admin | treasurer |
        // secretary` côté /users. Aligné sur l'accès à la page
        // `/license-requests` (admin/treasurer/secretary + rootAdmin bypass)
        // et sur les callables `treasurerReviewLicenseDoc` /
        // `validateLicenseRequest` / `confirmLicense`. Toutes les
        // affectedKeys utilisent `hasOnly` pour bloquer toute écriture
        // hors scope. La transition de `status` est elle-même whitelistée
        // pour éviter qu'un caller saute des étapes.
        //
        // Note : la création de la `/licenses/{id}` à `sent_paid` et la
        // confirmation finale (`approved`) avec dénorm membre + écriture
        // comptable passent par des **callables Admin SDK** qui bypassent
        // ces rules (`treasurerMarkSentAndPaid`, `treasurerFinalizeLicense`).
        // Les rules ci-dessous sont des filets de sécurité pour un éventuel
        // write client direct.
        //
        // Pourquoi `.data.get('signableDocStoragePath', null)` partout : les
        // demandes legacy en `coach_validated` n'ont pas ces champs ; un
        // accès direct `.data.field` throw côté Rules engine et refuse la
        // LIST query en bloc (cf. mémoire `firestore-rules-safe-field-access`).
        // L'accès safe ici est défensif, même si en pratique on lit dans
        // `request.resource.data` (toujours non-null car affectedKeys whitelist).
        || (
          (isRootAdmin() || isAdmin() || isTreasurer() || isSecretary())
          && (
            // coach_validated → awaiting_parent_signature
            (
              resource.data.status == 'coach_validated'
              && request.resource.data.status == 'awaiting_parent_signature'
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['status',
                             'signableDocStoragePath',
                             'signableDocUploadedAt',
                             'signableDocUploadedByUid'])
            )
            // parent_signed → form_confirmed
            || (
              resource.data.status == 'parent_signed'
              && request.resource.data.status == 'form_confirmed'
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['status',
                             'formConfirmedAt',
                             'formConfirmedByUid',
                             'treasurerNotes'])
            )
            // form_confirmed → sent_paid (canal callable normalement —
            // filet de sécurité ici, sans création /licenses côté client).
            || (
              resource.data.status == 'form_confirmed'
              && request.resource.data.status == 'sent_paid'
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['status',
                             'sentToFederationAt',
                             'paidAt',
                             'paymentProofStoragePath',
                             'paymentProofUploadedAt',
                             'linkedLicenseId',
                             'treasurerNotes'])
            )
            // Re-upload paymentProof à status sent_paid (workflow asynchrone)
            || (
              resource.data.status == 'sent_paid'
              && request.resource.data.status == 'sent_paid'
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['paymentProofStoragePath',
                             'paymentProofUploadedAt'])
            )
            // sent_paid → approved (canal callable normalement — filet
            // de sécurité ici, sans confirmation /licenses côté client).
            || (
              resource.data.status == 'sent_paid'
              && request.resource.data.status == 'approved'
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['status',
                             'licenseNumber',
                             'licenseFinalizedAt',
                             'licenseFinalizedByUid',
                             'treasurerNotes'])
            )
          )
        )
        // ===================================================================
        // Parent re-upload signed doc — awaiting_parent_signature → parent_signed
        // ===================================================================
        // Le parent re-uploade le doc signé. Transition côté parent (pas
        // de callable — l'UI register est différée hors PR3, mais la rule
        // est posée pour que la fonctionnalité soit débloquable sans
        // re-deploy quand l'UI atterrira).
        || (
          (
            (isSignedIn()
              && request.auth.uid in resource.data.get('parentUserIds', []))
            || isLinkedMember(resource.data.memberId)
            || isGuardianOf(resource.data.memberId)
          )
          && resource.data.status == 'awaiting_parent_signature'
          && request.resource.data.status == 'parent_signed'
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status',
                         'signedDocStoragePath',
                         'signedDocUploadedAt',
                         'signedDocUploadedByUid'])
        );
      allow delete: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /licenses  — instances de licences fédérales émises
    // ========================================================================
    // Un doc `/licenses/{id}` = une licence émise pour un membre × saison ×
    // type de licence (role, level, feeSnapshot snapshottés). Cf.
    // docs/firebase.md (/licenses) + docs/main.md (Licences).
    //
    // Cycle de vie :
    //  - `pending`   : créée par l'admin depuis la fiche membre (write client
    //                  direct couvert par la clause `create` ci-dessous).
    //  - `active`    : confirmée (fédération + paiement club). Le passage en
    //                  `active` — qui pose aussi `accountingEntryId`,
    //                  `confirmedAt`, `confirmedByUid` et la réf dénormalisée
    //                  `member.officialLicense` / `coachLicense` + poste
    //                  l'écriture comptable de la charge — passe par la
    //                  callable `confirmLicense` (Admin SDK, qui BYPASSE ces
    //                  rules et re-vérifie le scope treasurer/admin/secretary/
    //                  rootAdmin côté serveur). On n'ouvre donc PAS treasurer
    //                  ni secretary en write direct ici : la rule `update`
    //                  reste serrée sur admin/rootAdmin (filets de sécurité).
    //  - `cancelled` : terminal.
    //
    // Lecture : staff (rootAdmin/admin/coach/treasurer/secretary), le membre
    // lié, et ses tuteurs — chacun peut consulter sa propre licence. PAS de
    // garde `!callerSuspended()` : comme `/dues`, un membre inactif garde la
    // lecture de sa propre licence.
    //
    // Pas d'index composite : les lectures `where memberId == X` portent sur
    // < 100 docs → simple query + tri JS côté client (règle 10 du CLAUDE.md).
    match /licenses/{id} {
      allow read: if isRootAdmin() || isAdmin() || isCoach()
        || isTreasurer() || isSecretary()
        || isLinkedMember(resource.data.memberId)
        || isGuardianOf(resource.data.memberId);
      // Create : admin/rootAdmin — création en `pending` depuis la fiche membre.
      allow create: if isRootAdmin() || isAdmin();
      // Update/delete : admin/rootAdmin uniquement. La confirmation
      // (`status: 'active'` + `accountingEntryId`) passe par la callable
      // `confirmLicense` en Admin SDK — voir commentaire du bloc ci-dessus.
      allow update, delete: if isRootAdmin() || isAdmin();
    }

    // ========================================================================
    // /registrations  — inscriptions self-service via app courtbase-register
    // ========================================================================
    // Cf. docs/chantier-registrations.md. Les transitions de status post-`submitted`
    // passent par callables (refuseRegistration, etc.) — pas de write direct client.
    match /registrations/{registrationId} {
      allow read: if isSignedIn() && (
        resource.data.submittedByUid == request.auth.uid
        || (resource.data.matchedMemberId != null && isGuardianOf(resource.data.matchedMemberId))
        || isCoachOfTeam(resource.data.teamId)
        || isAdmin()
        || isRootAdmin()
      );
      // Create : auteur uniquement, status forcé à 'draft' ou 'submitted' au create.
      allow create: if isSignedIn()
        && request.resource.data.submittedByUid == request.auth.uid
        && request.resource.data.status in ['draft', 'submitted'];
      // Update : autorisé sur SON propre draft tant qu'il est en `draft` (autosave wizard).
      // Toute autre transition de status (submitted → open_pending_trial, refused, etc.)
      // passe par callables côté Admin SDK.
      allow update: if isSignedIn()
        && resource.data.submittedByUid == request.auth.uid
        && resource.data.status == 'draft'
        && request.resource.data.submittedByUid == resource.data.submittedByUid;
      // Delete :
      //  (a) l'auteur, uniquement tant que la registration est encore un
      //      brouillon. Une fois soumise, il passe par la callable
      //      `cancelRegistration` (set status='cancelled', conserve l'audit).
      //  (b) admin / rootAdmin — suppression définitive depuis la vue
      //      Inscriptions (correction d'erreur). La voie normale d'extinction
      //      reste `cancelRegistration` ; un garde-fou côté repo refuse de
      //      supprimer une registration confirmée (member + cotisation créés).
      allow delete: if isSignedIn() && (
        (resource.data.submittedByUid == request.auth.uid
          && resource.data.status == 'draft')
        || isAdmin()
        || isRootAdmin()
      );
    }

    // ========================================================================
    // /pendingEmails/{emailId} — file d'attente d'emails sortants (server-only)
    // ========================================================================
    // Écrits par les Cloud Functions (Admin SDK bypass rules), lus par le worker
    // d'envoi (idem). Lockdown total côté client : défensif — empêche un client
    // mal-intentionné de lire des emails en attente ou d'en injecter.
    match /pendingEmails/{emailId} {
      allow read: if false;
      allow write: if false;
    }

    // ========================================================================
    // /_meta/schema — réservé migration runner
    // ========================================================================
    match /_meta/{doc} {
      allow read: if isRootAdmin() || isAdmin();
      allow write: if isRootAdmin();
      // En pratique écrit par runMigrations (Function avec privilèges Admin SDK).
    }
  }
}
